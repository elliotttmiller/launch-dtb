{
  "name": "drywall-toolbox-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://elliottm4.sg-host.com",
  "scripts": {
    "dev": "webpack serve --config webpack.config.cjs --mode development",
    "build": "npm run build:siteground-root",
    "build:siteground-root": "cross-env APP_ENV=production PUBLIC_URL=/ node scripts/assert-public-env-safe.cjs pre && node scripts/clean-build-artifacts.cjs production && cross-env APP_ENV=production PUBLIC_URL=/ webpack --config webpack.config.cjs --mode production && cross-env APP_ENV=production node scripts/assert-public-env-safe.cjs post",
    "build:staging": "cross-env APP_ENV=staging PUBLIC_URL=/staging/2972 node scripts/assert-public-env-safe.cjs pre && node scripts/clean-build-artifacts.cjs staging && cross-env APP_ENV=staging PUBLIC_URL=/staging/2972 webpack --config webpack.config.cjs --mode production && cross-env APP_ENV=staging node scripts/assert-public-env-safe.cjs post",
    "clean:build-cache": "node scripts/clean-build-artifacts.cjs cache",
    "reviews-server": "node server/index.js",
    "lint": "eslint src",
    "preview": "webpack serve --config webpack.config.cjs --mode production"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
