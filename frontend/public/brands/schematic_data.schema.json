{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://elliottm4.sg-host.com/schemas/schematic_data.schema.json",
  "title": "Drywall Toolbox Schematic Data Schema",
  "description": "Validation schema for interactive brand schematic hotspot data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "diagram",
    "parts_catalog",
    "hotspots"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "diagram": {
      "$ref": "#/$defs/diagram"
    },
    "parts_catalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/part"
      }
    },
    "hotspots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hotspot"
      }
    },
    "ui_defaults": {
      "$ref": "#/$defs/uiDefaults"
    },
    "validation": {
      "$ref": "#/$defs/validationConfig"
    }
  },
  "$defs": {
    "idString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "pages"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/idString"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/page"
          }
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "image",
        "coordinate_space"
      ],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "src",
            "natural_width",
            "natural_height"
          ],
          "properties": {
            "src": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000
            },
            "natural_width": {
              "type": "integer",
              "minimum": 1
            },
            "natural_height": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "coordinate_space": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "origin",
            "x_axis",
            "y_axis",
            "unit"
          ],
          "properties": {
            "origin": {
              "type": "string",
              "enum": [
                "top-left"
              ]
            },
            "x_axis": {
              "type": "string",
              "enum": [
                "right"
              ]
            },
            "y_axis": {
              "type": "string",
              "enum": [
                "down"
              ]
            },
            "unit": {
              "type": "string",
              "enum": [
                "px"
              ]
            }
          }
        }
      }
    },
    "part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part_id",
        "display_id",
        "name",
        "sku",
        "quantity"
      ],
      "properties": {
        "part_id": {
          "$ref": "#/$defs/idString"
        },
        "display_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "sku": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "hotspot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hotspot_id",
        "part_ref",
        "page",
        "shape"
      ],
      "properties": {
        "hotspot_id": {
          "$ref": "#/$defs/idString"
        },
        "part_ref": {
          "$ref": "#/$defs/idString"
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "shape": {
          "oneOf": [
            {
              "$ref": "#/$defs/shapeRect"
            },
            {
              "$ref": "#/$defs/shapeCircle"
            },
            {
              "$ref": "#/$defs/shapePolygon"
            }
          ]
        },
        "rotation_deg": {
          "type": "number",
          "default": 0
        },
        "anchor": {
          "type": "string",
          "enum": [
            "center",
            "top-left"
          ],
          "default": "center"
        },
        "z_index": {
          "type": "integer"
        },
        "interaction": {
          "$ref": "#/$defs/interaction"
        },
        "normalized": {
          "oneOf": [
            {
              "$ref": "#/$defs/normalizedRect"
            },
            {
              "$ref": "#/$defs/normalizedCircle"
            },
            {
              "$ref": "#/$defs/normalizedPolygon"
            }
          ]
        }
      }
    },
    "shapeRect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "x_px",
        "y_px",
        "width_px",
        "height_px"
      ],
      "properties": {
        "type": {
          "const": "rect"
        },
        "x_px": {
          "type": "number"
        },
        "y_px": {
          "type": "number"
        },
        "width_px": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height_px": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "shapeCircle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "cx_px",
        "cy_px",
        "r_px"
      ],
      "properties": {
        "type": {
          "const": "circle"
        },
        "cx_px": {
          "type": "number"
        },
        "cy_px": {
          "type": "number"
        },
        "r_px": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "shapePolygon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "points_px"
      ],
      "properties": {
        "type": {
          "const": "polygon"
        },
        "points_px": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          }
        }
      }
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tap_target_min_px": {
          "type": "number",
          "minimum": 0
        },
        "hit_slop_px": {
          "type": "number",
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "normalizedRect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x_pct",
        "y_pct",
        "width_pct",
        "height_pct"
      ],
      "properties": {
        "x_pct": {
          "type": "number"
        },
        "y_pct": {
          "type": "number"
        },
        "width_pct": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height_pct": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "normalizedCircle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cx_pct",
        "cy_pct",
        "r_pct_w",
        "r_pct_h"
      ],
      "properties": {
        "cx_pct": {
          "type": "number"
        },
        "cy_pct": {
          "type": "number"
        },
        "r_pct_w": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "r_pct_h": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "normalizedPolygon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "points_pct"
      ],
      "properties": {
        "points_pct": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          }
        }
      }
    },
    "uiDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shape_render": {
          "type": "string",
          "enum": [
            "auto",
            "rect",
            "circle",
            "polygon"
          ]
        },
        "show_labels": {
          "type": "boolean"
        },
        "hotspot_style": {
          "type": "string",
          "enum": [
            "outline",
            "fill",
            "minimal"
          ]
        },
        "tap_target_min_px": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "validationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_unique_hotspot_id": {
          "type": "boolean"
        },
        "require_part_ref_exists": {
          "type": "boolean"
        },
        "clamp_hotspots_to_page_bounds": {
          "type": "boolean"
        },
        "normalized_is_derived_from_px": {
          "type": "boolean"
        }
      }
    }
  }
}
