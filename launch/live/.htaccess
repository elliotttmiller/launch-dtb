DirectoryIndex index.html index.php

ErrorDocument 400 /errors/400.html
ErrorDocument 401 /errors/401.html
ErrorDocument 402 /errors/402.html
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 405 /errors/405.html
ErrorDocument 406 /errors/406.html
ErrorDocument 408 /errors/408.html
ErrorDocument 409 /errors/409.html
ErrorDocument 410 /errors/410.html
ErrorDocument 411 /errors/411.html
ErrorDocument 412 /errors/412.html
ErrorDocument 413 /errors/413.html
ErrorDocument 414 /errors/414.html
ErrorDocument 415 /errors/415.html
ErrorDocument 416 /errors/416.html
ErrorDocument 417 /errors/417.html
ErrorDocument 421 /errors/421.html
ErrorDocument 422 /errors/422.html
ErrorDocument 423 /errors/423.html
ErrorDocument 424 /errors/424.html
ErrorDocument 426 /errors/426.html
ErrorDocument 428 /errors/428.html
ErrorDocument 429 /errors/429.html
ErrorDocument 431 /errors/431.html
ErrorDocument 451 /errors/451.html
ErrorDocument 500 /errors/500.html
ErrorDocument 501 /errors/501.html
ErrorDocument 502 /errors/502.html
ErrorDocument 503 /errors/503.html
ErrorDocument 504 /errors/504.html
ErrorDocument 505 /errors/505.html
ErrorDocument 507 /errors/507.html
ErrorDocument 508 /errors/508.html
ErrorDocument 511 /errors/511.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # WordPress is physically installed in /wp, while the React SPA owns the
  # public document root. Route WordPress/WooCommerce entry points to /wp
  # before the SPA fallback so admin, REST, checkout, and callbacks do not
  # render the React 404 shell.
  RewriteRule ^wp-json/?$ wp/index.php?rest_route=/ [QSA,L]
  RewriteRule ^wp-json/(.*)$ wp/index.php?rest_route=/$1 [QSA,L]
  RewriteRule ^wp-admin/?$ wp/wp-admin/ [R=302,L]
  RewriteRule ^wp-admin/(.*)$ wp/wp-admin/$1 [QSA,L]
  RewriteRule ^wp-includes/(.*)$ wp/wp-includes/$1 [QSA,L]
  RewriteRule ^wp-content/(.*)$ wp/wp-content/$1 [QSA,L]
  RewriteRule ^wp-login\.php$ wp/wp-login.php [QSA,L]
  RewriteRule ^wp-cron\.php$ wp/wp-cron.php [QSA,L]
  RewriteRule ^xmlrpc\.php$ wp/xmlrpc.php [QSA,L]
  RewriteRule ^wp-comments-post\.php$ wp/wp-comments-post.php [QSA,L]

  # Native WooCommerce/WordPress storefront routes must be served by WP.
  RewriteRule ^checkout/?$ wp/index.php?pagename=checkout [QSA,L]
  RewriteRule ^cart/?$ wp/index.php?pagename=cart [QSA,L]
  RewriteRule ^my-account/?$ wp/index.php?pagename=my-account [QSA,L]
  RewriteRule ^order-pay(/.*)?$ wp/index.php [QSA,L]
  RewriteRule ^order-received(/.*)?$ wp/index.php [QSA,L]
  RewriteRule ^wc-api(/.*)?$ wp/index.php [QSA,L]

  # Serve uploaded static assets directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Missing assets should stay 404s instead of receiving the SPA shell.
  RewriteCond %{REQUEST_URI} \.(?:css|js|mjs|map|json|webmanifest|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf|eot|pdf|txt|xml)$ [NC]
  RewriteRule ^ - [R=404,L]

  # React Router deep-link fallback for cPanel/Apache subdirectory deploys.
  # Do NOT intercept WordPress REST, admin, or wp/ subdirectory paths — those
  # must reach Apache/PHP directly, never the SPA shell.
  RewriteCond %{REQUEST_URI} !^/(wp-json|wp-admin|wp)(/|$)
  RewriteCond %{REQUEST_URI} !^/(wp-login\.php|wp-cron\.php|xmlrpc\.php|wp-comments-post\.php)$
  RewriteCond %{REQUEST_URI} !^/(checkout|cart|my-account|order-pay|order-received|wc-api)(/|$)
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "^(index|404)\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "^[45][0-9]{2}\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
