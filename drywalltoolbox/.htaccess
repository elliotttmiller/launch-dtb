# Drywall Toolbox live root routing
# SiteGround document root: the directory serving elliottm4.sg-host.com
# WordPress core: document-root/wp/
# React build: upload the CONTENTS of dist/ into this document root.

DirectoryIndex index.html index.php
Options -Indexes
Options +FollowSymLinks
FileETag None

ErrorDocument 400 /errors/400.html
ErrorDocument 401 /errors/401.html
ErrorDocument 402 /errors/402.html
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 405 /errors/405.html
ErrorDocument 406 /errors/406.html
ErrorDocument 408 /errors/408.html
ErrorDocument 409 /errors/409.html
ErrorDocument 410 /errors/410.html
ErrorDocument 411 /errors/411.html
ErrorDocument 412 /errors/412.html
ErrorDocument 413 /errors/413.html
ErrorDocument 414 /errors/414.html
ErrorDocument 415 /errors/415.html
ErrorDocument 416 /errors/416.html
ErrorDocument 417 /errors/417.html
ErrorDocument 421 /errors/421.html
ErrorDocument 422 /errors/422.html
ErrorDocument 423 /errors/423.html
ErrorDocument 424 /errors/424.html
ErrorDocument 426 /errors/426.html
ErrorDocument 428 /errors/428.html
ErrorDocument 429 /errors/429.html
ErrorDocument 431 /errors/431.html
ErrorDocument 451 /errors/451.html
ErrorDocument 500 /errors/500.html
ErrorDocument 501 /errors/501.html
ErrorDocument 502 /errors/502.html
ErrorDocument 503 /errors/503.html
ErrorDocument 504 /errors/504.html
ErrorDocument 505 /errors/505.html
ErrorDocument 507 /errors/507.html
ErrorDocument 508 /errors/508.html
ErrorDocument 511 /errors/511.html

# Block accidental public reads of secrets, backups, logs, and local build files.
<FilesMatch "(^\.|wp-config\.php$|\.env(?:\..*)?$|composer\.(?:json|lock)$|package-lock\.json$|package\.json$|.*\.(?:bak|backup|old|orig|save|sql|sqlite|log|ini|sh|ps1|pem|key)$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Explicit MIME types prevent JS/CSS from being served as text/html by host defaults.
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType text/plain .txt
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Preserve Authorization headers for PHP/WordPress auth handlers.
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # Bridge2Cart / Veeqo bridge — serve directly, skip all rewrites.
  RewriteRule ^bridge2cart/ - [L]

  # Force HTTPS in production.
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !^https$ [NC]
  RewriteCond %{HTTP_HOST} !^localhost$ [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
  RewriteRule ^ https://elliottm4.sg-host.com%{REQUEST_URI} [R=301,L,NE]

  # Canonical host. Redirect only recognized legacy hosts; never reflect an
  # arbitrary Host header into Location. This keeps storefront, Woo session,
  # DTB auth, checkout, and Stripe return URLs on one origin.
  RewriteCond %{HTTP_HOST} ^(?:www\.)?drywalltoolbox\.com$ [NC]
  RewriteRule ^ https://elliottm4.sg-host.com%{REQUEST_URI} [R=301,L,NE]

  # Apple Pay / official WooCommerce Stripe gateway domain association.
  # The official Stripe extension can create the required association file. If
  # WordPress writes it below /wp because core lives in that subdirectory, expose
  # the non-empty generated copy at the public domain-root URL Apple verifies.
  RewriteCond %{DOCUMENT_ROOT}/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association$ .well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{DOCUMENT_ROOT}/wp/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association$ wp/.well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{DOCUMENT_ROOT}/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association\.txt$ .well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{DOCUMENT_ROOT}/wp/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association\.txt$ wp/.well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{REQUEST_URI} ^/\.well-known/apple-developer-merchantid-domain-association(?:\.txt)?/?$ [NC]
  RewriteRule ^ - [R=404,L]

  # Route root/query-string REST fallback into WordPress before the SPA homepage.
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^$ wp/index.php [QSA,L]

  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^index\.php$ wp/index.php [QSA,L]

  # Root REST aliases -> WordPress in /wp.
  RewriteRule ^wp-json/?$ wp/index.php?rest_route=/ [QSA,L]
  RewriteRule ^wp-json/(.*)$ wp/index.php?rest_route=/$1 [QSA,L]
  RewriteRule ^dtb/(.*)$ wp/index.php?rest_route=/dtb/$1 [QSA,L]

  # Staging REST aliases -> WordPress in /wp.
  RewriteRule ^staging/2972/wp-json/?$ wp/index.php?rest_route=/ [QSA,L]
  RewriteRule ^staging/2972/wp-json/(.*)$ wp/index.php?rest_route=/$1 [QSA,L]
  RewriteRule ^staging/2972/dtb/(.*)$ wp/index.php?rest_route=/dtb/$1 [QSA,L]

  RewriteCond %{REQUEST_URI} ^/staging/2972/?$ [NC]
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^staging/2972/?$ wp/index.php [QSA,L]

  # WooCommerce/official Stripe callbacks. The official Stripe extension uses
  # WooCommerce's wc-api callback space (for example ?wc-api=wc_stripe).
  RewriteCond %{QUERY_STRING} (^|&)wc-api= [NC]
  RewriteRule ^(?:index\.php)?$ wp/index.php [QSA,L]
  RewriteRule ^wc-api/?$ wp/index.php [QSA,L]
  RewriteRule ^staging/2972/wc-api/?$ wp/index.php [QSA,L]

  # WooCommerce Checkout Block is the authoritative storefront checkout surface.
  RewriteRule ^checkout/?$ wp/index.php?pagename=checkout [QSA,L]
  RewriteRule ^staging/2972/checkout/?$ wp/index.php?pagename=checkout [QSA,L]

  # Canonicalize wp-prefixed WooCommerce payment endpoints back to the public checkout URL.
  RewriteRule ^wp/checkout/order-pay/(.*)$ /checkout/order-pay/$1 [R=302,L,QSA]
  RewriteRule ^wp/order-pay/(.*)$ /checkout/order-pay/$1 [R=302,L,QSA]
  RewriteRule ^wp/checkout/order-received/(.*)$ /checkout/order-received/$1 [R=302,L,QSA]

  # WooCommerce payment/order-pay endpoints must be handled by WordPress, not by the React SPA shell.
  RewriteRule ^checkout/order-pay/([0-9]+)/?$ wp/index.php?pagename=checkout&order-pay=$1 [QSA,L]
  RewriteRule ^order-pay/([0-9]+)/?$ wp/index.php?pagename=checkout&order-pay=$1 [QSA,L]
  RewriteRule ^staging/2972/checkout/order-pay/([0-9]+)/?$ wp/index.php?pagename=checkout&order-pay=$1 [QSA,L]

  # WooCommerce order-received/thank-you endpoints must also remain in WordPress.
  RewriteRule ^checkout/order-received/([0-9]+)/?$ wp/index.php?pagename=checkout&order-received=$1 [QSA,L]
  RewriteRule ^staging/2972/checkout/order-received/([0-9]+)/?$ wp/index.php?pagename=checkout&order-received=$1 [QSA,L]

  # Reduced/query-string order-pay shapes must also remain in WooCommerce.
  RewriteCond %{QUERY_STRING} (^|&)(pay_for_order=true|order-pay=[0-9]+)(&|$) [NC]
  RewriteCond %{QUERY_STRING} (^|&)key=wc_order_ [NC]
  RewriteRule ^checkout/?$ wp/index.php?pagename=checkout [QSA,L]

  RewriteCond %{QUERY_STRING} (^|&)(pay_for_order=true|order-pay=[0-9]+)(&|$) [NC]
  RewriteCond %{QUERY_STRING} (^|&)key=wc_order_ [NC]
  RewriteRule ^staging/2972/checkout/?$ wp/index.php?pagename=checkout [QSA,L]

  # Prevent SiteGround/nginx and browser caching on admin/auth and
  # customer/session-owned surfaces.
  <IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/(?:wp-admin|wp-login\.php|wp-json|dtb|wp-cron\.php|xmlrpc\.php|cart|checkout|account|my-account|dashboard|orders|addresses|rewards|login|register|forgot-password|lost-password|reset-password|logout|wc-api)(?:/|$)#i || %{REQUEST_URI} =~ m#/checkout/order-pay/#i || %{QUERY_STRING} =~ m#(^|&)(?:rest_route=|pay_for_order=true|order-pay=[0-9]+|wc-api=)#i || %{HTTP_COOKIE} =~ m#(?:^|;\s*)(?:wordpress_logged_in_|wordpress_sec_|wordpress_test_cookie|wp-settings-|woocommerce_cart_hash|woocommerce_items_in_cart|wp_woocommerce_session_|dtb_auth)#i">
      Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, private"
      Header always set Pragma "no-cache"
      Header always set Expires "0"
      Header always set X-Accel-Expires "0"
      Header always merge Vary Cookie
      Header always merge Vary Authorization
    </If>
  </IfModule>

  # Force homepage to the static React landing page after API fallbacks.
  RewriteRule ^$ index.html [L]

  RewriteRule ^favicon\.ico$ logos/favicon.ico [L]

  # WordPress admin/login aliases. These must remain internal rewrites: a
  # browser-followed 302 changes login/admin POST requests to GET and drops the
  # submitted credentials, action, nonce, file mapping, and batch position.
  RewriteRule ^wp-admin/admin-ajax\.php$ wp/wp-admin/admin-ajax.php [L,QSA]
  RewriteRule ^wp-admin/?$ wp/wp-admin/ [L,QSA]
  RewriteRule ^wp-admin/(.*)$ wp/wp-admin/$1 [L,QSA]
  RewriteRule ^wp-login\.php$ wp/wp-login.php [L,QSA]

  # Expose WordPress asset/core paths at root for compatibility.
  RewriteRule ^wp-content/(.*)$ wp/wp-content/$1 [L,QSA]
  RewriteRule ^wp-includes/(.*)$ wp/wp-includes/$1 [L,QSA]
  RewriteRule ^wp-cron\.php$ wp/wp-cron.php [L,QSA]
  RewriteRule ^xmlrpc\.php$ wp/xmlrpc.php [L,QSA]

  # Staging SPA deep-link fallback. Checkout is already consumed by the explicit rules above.
  RewriteCond %{REQUEST_URI} ^/staging/2972/ [NC]
  RewriteCond %{REQUEST_URI} !^/staging/2972/(?:wp-json|dtb)(?:/|$) [NC]
  RewriteCond %{REQUEST_URI} !^/staging/2972/checkout(?:/|$) [NC]
  RewriteCond %{REQUEST_URI} !\.(?:css|js|mjs|map|json|webmanifest|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf|eot|pdf|txt|xml)$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^staging/2972/ /staging/2972/index.html [QSA,L]

  # Serve existing files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Keep direct /wp/* requests in WordPress' own rewrite scope.
  RewriteCond %{REQUEST_URI} ^/wp/ [NC]
  RewriteRule ^ - [L]

  # Do not serve the SPA shell for missing static assets or verification files.
  RewriteCond %{REQUEST_URI} \.(?:css|js|mjs|map|json|webmanifest|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf|eot|pdf|txt|xml)$ [NC,OR]
  RewriteCond %{REQUEST_URI} ^/\.well-known/ [NC]
  RewriteRule ^ - [R=404,L]

  # Root React Router SPA catch-all.
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
  Header unset ETag
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  # Delegate Payment Request only to the official Stripe/Google Pay frame chain.
  # Keep this synchronized with dtb_frontend_security_permissions_policy().
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(self \"https://js.stripe.com\" \"https://hooks.stripe.com\" \"https://b.stripecdn.com\" \"https://pay.google.com\"), usb=(), browsing-topics=()"
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "^[45][0-9]{2}\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Stable public media and font assets are versioned operationally. Keep them
  # browser-cacheable while allowing a bounded refresh window for logo updates.
  <FilesMatch "\.(?:avif|webp|png|jpe?g|gif|svg|ico|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
  </FilesMatch>

  # Official Stripe/Apple Pay domain association should be revalidated during gateway/domain setup.
  <FilesMatch "^apple-developer-merchantid-domain-association$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
