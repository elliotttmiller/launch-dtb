# Drywall Toolbox live root routing
# Document root: /public_html/drywalltoolbox/
# WordPress core: /public_html/drywalltoolbox/wp/
# React build: upload the CONTENTS of dist/ into this document root.

DirectoryIndex index.html index.php
Options -Indexes
Options +FollowSymLinks

# Explicit MIME types prevent JS/CSS from being served as text/html by host defaults.
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType text/plain .txt
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Preserve Authorization headers for PHP/WordPress auth handlers.
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # Force HTTPS in production.
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} !^localhost$ [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Canonical host. Keep the public site and WordPress cookies on one host.
  RewriteCond %{HTTP_HOST} ^www\.drywalltoolbox\.com$ [NC]
  RewriteRule ^ https://drywalltoolbox.com%{REQUEST_URI} [R=301,L]

  # Apple Pay / Stripe / WooPayments domain-association verification.
  # This extensionless file must be served as a real static file and must never
  # fall through to the React/coming-soon shell. Upload the provider-issued file
  # to /public_html/drywalltoolbox/.well-known/apple-developer-merchantid-domain-association.
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association$ .well-known/apple-developer-merchantid-domain-association [L]
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association\.txt$ .well-known/apple-developer-merchantid-domain-association [L]
  RewriteCond %{REQUEST_URI} ^/\.well-known/apple-developer-merchantid-domain-association/?$ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ - [R=404,L]

  # Route root/query-string REST fallback into WordPress before the SPA homepage.
  # Woo.com and some diagnostics probe ?rest_route=/ instead of /wp-json/.
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^$ wp/index.php [QSA,L]

  # Route direct rest_route=index.php calls into /wp/index.php.
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^index\.php$ wp/index.php [QSA,L]

  # Root REST aliases -> WordPress in /wp.
  RewriteRule ^wp-json/?$ wp/index.php?rest_route=/ [QSA,L]
  RewriteRule ^wp-json/(.*)$ wp/index.php?rest_route=/$1 [QSA,L]
  RewriteRule ^dtb/(.*)$ wp/index.php?rest_route=/dtb/$1 [QSA,L]

  # WooCommerce legacy callback/API compatibility from the root URL space.
  RewriteCond %{QUERY_STRING} (^|&)wc-api= [NC]
  RewriteRule ^$ wp/index.php [QSA,L]

  # Canonicalize wp-prefixed WooCommerce payment endpoints back to the public
  # checkout URL. WooCommerce order-pay is a checkout endpoint, not a React route;
  # when served under /wp/checkout/order-pay it can miss the public checkout page
  # context and fall through to the coming-soon/front-page template.
  RewriteRule ^wp/checkout/order-pay/(.*)$ /checkout/order-pay/$1 [R=302,L,QSA]
  RewriteRule ^wp/order-pay/(.*)$ /checkout/order-pay/$1 [R=302,L,QSA]

  # WooCommerce payment/order-pay endpoints must be handled by WordPress, not by
  # the React SPA shell. Without this rule, secure-payment redirects can fall
  # back into the public landing/coming-soon page instead of the payment runtime.
  RewriteRule ^checkout/order-pay/.*$ wp/index.php [QSA,L]
  RewriteRule ^checkout/.*order-pay.*$ wp/index.php [QSA,L]
  RewriteRule ^order-pay/.*$ wp/index.php [QSA,L]

  # Force homepage to the static React landing page after API fallbacks.
  RewriteRule ^$ index.html [L]

  # Conventional browser favicon path backed by the shared logo assets folder.
  RewriteRule ^favicon\.ico$ logos/favicon.ico [L]

  # WordPress admin/login aliases from the root URL space.
  RewriteRule ^wp-admin/?$ wp/wp-admin/ [L,QSA]
  RewriteRule ^wp-admin/(.*)$ wp/wp-admin/$1 [L,QSA]
  RewriteRule ^wp-login\.php$ wp/wp-login.php [L,QSA]

  # Expose WordPress asset/core paths at root for compatibility.
  RewriteRule ^wp-content/(.*)$ wp/wp-content/$1 [L,QSA]
  RewriteRule ^wp-includes/(.*)$ wp/wp-includes/$1 [L,QSA]
  RewriteRule ^wp-cron\.php$ wp/wp-cron.php [L,QSA]
  RewriteRule ^xmlrpc\.php$ wp/xmlrpc.php [L,QSA]

  # Staging SPA deep-link fallback.
  RewriteCond %{REQUEST_URI} ^/staging/2972/ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^staging/2972/ /staging/2972/index.html [QSA,L]

  # Serve existing files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Keep direct /wp/* requests in WordPress' own rewrite scope.
  RewriteCond %{REQUEST_URI} ^/wp/ [NC]
  RewriteRule ^ - [L]

  # Do not serve the SPA shell for missing static assets or verification files.
  # Returning HTML for missing JS/CSS/provider verification paths causes blank
  # screens, MIME/type failures, and Apple Pay domain-verification failures.
  RewriteCond %{REQUEST_URI} (?:\.(?:css|js|mjs|map|json|webmanifest|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf|eot|pdf|txt|xml)$|^/\.well-known/) [NC]
  RewriteRule ^ - [R=404,L]

  # Root React Router SPA catch-all.
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
  # HTML shell must revalidate so clients pick up newly deployed asset paths.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Apple Pay / Stripe domain association files must not be cached aggressively
  # while verification is being repaired.
  <FilesMatch "^apple-developer-merchantid-domain-association$">
    Header set Content-Type "text/plain; charset=utf-8"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Stable JS/CSS/media asset names are deployment-controlled. Revalidate rather
  # than immutable-cache to avoid stale bundles on shared hosting/manual uploads.
  <FilesMatch "\.(?:js|mjs|css|json|webmanifest)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:png|jpe?g|gif|webp|avif|svg|ico|woff2?|woff|ttf|otf|eot|pdf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>